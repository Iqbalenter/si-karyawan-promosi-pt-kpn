rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fungsi bantuan untuk mengecek role
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    function isHRD() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'HRD';
    }
    
    function isPimpinan() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Pimpinan';
    }
    
    // Default: Tolak semua akses
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Karyawan collection
    match /karyawan/{karyawanId} {
      allow read: if request.auth != null; // Semua role bisa baca (Admin, HRD, Pimpinan)
      allow write: if isAdmin() || isHRD(); // Admin dan HRD bisa mengelola data karyawan
    }
    
    // Jabatan collection
    match /jabatan/{jabatanId} {
      allow read: if request.auth != null;
      allow write: if isAdmin(); // Hanya Admin yang mengelola struktur jabatan
    }
    
    // Kriteria collection
    match /kriteria/{kriteriaId} {
      allow read: if request.auth != null;
      allow write: if isAdmin(); // Sesuai requirement: "User selain admin tidak boleh mengubah kriteria dan bobot"
    }
    
    // Penilaian collection
    match /penilaian/{penilaianId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isHRD(); // Admin dan HRD bisa menginput nilai
    }
    
    // Hasil SAW collection
    match /hasil_saw/{hasilId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isHRD(); // Admin dan HRD yang menjalankan perhitungan dan menyimpan
    }
    
    // Audit logs collection
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if request.auth != null; // Semua user bisa menambah log
      allow update, delete: if false; // Log tidak boleh diubah/dihapus
    }
  }
}
